{
  "name": "xd_nextjs",
  "version": "1.9.0",
  "description": "XD-Shop",
  "workspaces": [
    "frontend/xdstudio"
  ],
  "scripts": {
    "update": "npx npm-check-updates --dep prod,dev --upgrade",
    "dev:frontend": "npm --prefix frontend/xdstudio run dev",
    "dev:backend": "npm --prefix backend/xdstudio  run dev",
    "prisma:studio": "npm --prefix backend/xdstudio run prisma:studio",
    "dev": "concurrently \"npm run dev:frontend/xdstudio\" \"npm run dev:backend\"",
    "build:frontend": "npm --prefix frontend/xdstudio  run build",
    "build:backend": "npm --prefix backend/xdstudio  run build",
    "build": "npm run build:frontend/xdstudio && npm run build:backend/xdstudio ",
    "prepare": "husky",
    "codegen": "graphql-codegen --config codegen.ts --no-cache --watch",
    "release": "npx standard-version && git push --follow-tags origin main"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KhunThynne/XDNEXT.JS.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/KhunThynne/XDNEXT.JS/issues"
  },
  "homepage": "https://github.com/KhunThynne/XDNEXT.JS#readme",
  "devDependencies": {
    "@0no-co/graphqlsp": "^1.15.3",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@graphql-codegen/cli": "^6.2.1",
    "@graphql-codegen/client-preset": "^5.2.4",
    "@graphql-codegen/introspection": "5.0.1",
    "@graphql-codegen/schema-ast": "^5.0.1",
    "@graphql-codegen/typescript": "^5.0.9",
    "@graphql-codegen/typescript-operations": "^5.0.9",
    "@graphql-codegen/typescript-react-query": "^7.0.0",
    "@parcel/watcher": "^2.5.6",
    "@types/node": "^25.5.2",
    "dotenv-flow": "^4.1.0",
    "husky": "^9.1.7",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "standard-version": "^9.5.0"
  },
  "dependencies": {
    "@next/env": "^16.2.3"
  }
}
