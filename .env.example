# ==============================================================================
# ENVIRONMENT VARIABLES
# ==============================================================================

# === 🏗️ DATABASE CONFIGURATION ===
# Core database connection details

# Database engine type (e.g., postgres)
DB_TYPE=<The type of database engine you are using. Example: postgres>
# Database Host/Server
DB_HOST=<The hostname or IP address of your database server. Example: localhost or 127.0.0.1>
# Database Port
DB_PORT=<The port number your database server is listening on. Example: 5432 (Postgres default)>
# Database User
DB_USER=<The username for authenticating with your database. Example: postgres>
# Database Password
DB_PASS=<The password for authenticating with your database. Example: mysecretpassword>
# Main Database Name
DB_NAME=<The name of the main database to connect to. Example: xdstudio>

# === 🔗 CONNECTION STRINGS ===
# Combined URLs used by Prisma, Payload CMS, and other services
# Syntax: postgresql://USER:PASSWORD@HOST:PORT/DB_NAME

# Main Database Connection URL
DATABASE_URL=<The full connection string for your primary database. Example: postgresql://postgres:password@localhost:5432/xdstudio?schema=public>
# Shadow Database URL (used for Prisma Migrate)
SHADOW_DATABASE_URL=<A separate database used temporarily by Prisma during migrations. Example: postgresql://postgres:password@localhost:5432/shadow-database>
# Alternative Postgres URL
POSTGRES_URL=<An alternative variable name for your standard database connection string. Example: ${DATABASE_URL}>

# Redis cache server URL
REDIS_URL=<The connection string for your Redis instance. Example: redis://127.0.0.1:6379>
# Redis Host
REDIS_HOST=<The hostname or IP address of your Redis server. Example: 127.0.0.1>
# Redis Port
REDIS_PORT=<The port number your Redis server is listening on. Example: 6379>

# === 🔐 SECURITY & AUTHENTICATION ===
# Secrets for encryption and session management

# General Secret Key (used for various cryptography or generic JWT)
SECRET_KEY=<A strong, randomly generated string used for general cryptographic operations. Example: my_super_secret_key_123>
# Session Secret Key for session encryption
SESSION_SECRET=<A strong, randomly generated string used to encrypt user sessions. Example: my_session_secret_456>
# Payload CMS Secret
PAYLOAD_SECRET=<A strong, randomly generated string used by Payload CMS for authentication and encryption. Example: payload_secret_key_789>

# Secret Key for signing/verifying Access Tokens
JWT_ACCESS_SECRET=<A secure random string used to sign JSON Web Tokens for authentication. Example: jwt_access_secret_abc>
# Secret Key for signing/verifying Refresh Tokens
JWT_REFRESH_SECRET=<A secure random string used to sign Refresh Tokens. Example: jwt_refresh_secret_def>
# Access Token Expiration time (e.g., 15m, 1h)
JWT_ACCESS_EXPIRES=<The duration until an access token expires. Example: 15m or 1h>
# Refresh Token Expiration time (e.g., 7d, 30d)
JWT_REFRESH_EXPIRES=<The duration until a refresh token expires. Example: 7d or 30d>

# === 🌐 URL/ENDPOINT CONFIGURATION ===

# Internal URL for the Site/API
INTERNAL_SITE_URL=<The internal URL used by backend services to communicate with the frontend. Example: http://localhost:3000>
# Internal / Private URL for the API
PRIVATE_SITE_URL=<The internal URL used to communicate with the private API server. Example: http://localhost:3001>
# Public URL for the Site/Frontend
PUBLIC_SITE_URL=<The publicly accessible URL of your frontend application. Example: https://www.yourdomain.com>
# Endpoint for the XD Core API
XD_CORE_API_URL=<The URL endpoint for the XD Core API service. Example: http://localhost:1215>


# === ⚙️ SYSTEM & MISC ===

# Token for Code Generation tasks
CODEGEN_TOKEN=<A secure token required to authorize code generation processes. Example: eyJhbGci_some_secret_jwt_token>
# Prisma CLI Target (for deployment, e.g., linux-musl)
PRISMA_CLI_BINARY_TARGETS=<The target operating system architecture for the Prisma engine. Example: native or linux-musl>
# Application Port
PORT=<The port number your web application runs on. Example: 3000>
# Node Environment
NODE_ENV=<The environment mode your application is running in. Example: development or production>
NEXT_PUBLIC_NODE_ENV=<The environment mode exposed to the Next.js frontend client-side code. Example: development or production>

# Host for KeystoneJS
KEYSTONE_HOST=<The hostname or IP address where KeystoneJS is running. Example: 127.0.0.1>

# === 🤖 DISCORD INTEGRATION ===

# Discord Application Public Key
DISCORD_PUBLIC_KEY=<Your Discord Application's Public Key. Found in the Discord Developer Portal. Example: a1b2c3d4e5f6...>
# Discord Bot Token
DISCORD_BOT_TOKEN=<Your Discord Bot's authentication token. Found in the Discord Developer Portal. Example: MTIzNDU2Nzg5.xyz...>

# === 💳 PAYMENT GATEWAYS ===

# Omise Public Key
OMISE_PUBLIC_KEY=<Your Omise Payment Gateway Public Key for client-side usage. Example: pkey_test_12345>
# Omise Secret Key
OMISE_SECRET_KEY=<Your Omise Payment Gateway Secret Key for server-side usage. Example: skey_test_12345>

# Stripe Webhook Secret (for verifying incoming webhooks)
STRIPE_WEBHOOK_SECRET=<The secret key used to verify that webhook payload requests from Stripe are authentic. Example: whsec_12345>
# Stripe Publishable Key
STRIPE_PUBLISHABLE_KEY=<Your Stripe Payment Gateway Publishable Key for client-side usage. Example: pk_test_12345>
# Stripe Secret Key
STRIPE_SECRET_KEY=<Your Stripe Payment Gateway Secret Key for server-side usage. Example: sk_test_12345>
