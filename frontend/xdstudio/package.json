{
  "name": "frontend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "workspaces": [
    "frontend/xdstudio",
    "backend/*"
  ],
  "scripts": {
    "dev": "next dev --no-server-fast-refresh",
    "build": "npx payload migrate&&next build --turbo",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "install:prod": "npm install --production",
    "update": "npx npm-check-updates --dep prod,dev --upgrade",
    "gen": "npm run generate:types && npm run generate:schema ",
    "generate:types": "set SKIP_ENV_VALIDATION=true&&npx payload generate:types",
    "generate:schema": "set SKIP_ENV_VALIDATION=true&&npx payload-graphql generate:schema",
    "generate:importmap": "set SKIP_ENV_VALIDATION=true&&npx payload generate:importmap",
    "release": "npx standard-version"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@next/env": "^16.2.4",
    "@payloadcms/db-postgres": "^3.83.0",
    "@payloadcms/next": "^3.83.0",
    "@payloadcms/richtext-lexical": "^3.83.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@stripe/react-stripe-js": "^6.2.0",
    "@stripe/stripe-js": "^9.2.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@tanstack/react-form": "^1.29.0",
    "@tanstack/react-query": "^5.99.2",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.24",
    "@wrksz/themes": "^0.8.3",
    "@xd/shared": "file:../../shared",
    "@zxing/browser": "^0.1.5",
    "babel-plugin-react-compiler": "^1.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "ctx": "^0.3.0",
    "downshift": "^9.3.2",
    "embla-carousel-react": "^8.6.0",
    "flexsearch": "^0.8.212",
    "graphql": "^16.13.2",
    "lucide-react": "^1.8.0",
    "motion": "^12.38.0",
    "next": "^16.2.4",
    "next-auth": "^5.0.0-beta.30",
    "next-intl": "^4.9.1",
    "payload": "^3.83.0",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.72.1",
    "redis": "^5.12.1",
    "sanitize-html": "^2.17.3",
    "sharp": "^0.34.5",
    "shiki": "^4.0.2",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "stripe": "^22.0.2",
    "swiper": "^12.1.3",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/migrate-config": "^2.0.6",
    "@next/eslint-plugin-next": "^16.2.4",
    "@parcel/watcher": "^2.5.6",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25",
    "@types/qrcode": "^1.5.6",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/sanitize-html": "^2.16.1",
    "eslint": "9.39.4",
    "eslint-config-next": "^16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-i18next": "^6.1.4",
    "eslint-plugin-jsonc": "^3.1.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-you-might-not-need-an-effect": "^0.9.3",
    "eslint-plugin-tailwindcss": "^4.0.0-beta.0",
    "jsonc-eslint-parser": "^3.1.0",
    "postcss": "^8.5.10",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "eslint-plugin-react-hooks": {
      "eslint": "$eslint"
    },
    "@tanstack/eslint-plugin-query": {
      "eslint": "$eslint"
    },
    "@t3-oss/env-core": {
      "typescript": "$typescript"
    },
    "next-intl": {
      "typescript": "$typescript"
    },
    "eslint-plugin-react": {
      "eslint": "$eslint"
    }
  }
}
